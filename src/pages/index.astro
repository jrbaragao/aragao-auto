---
import Layout from '../layouts/Layout.astro';
import Gallery from '../components/Gallery.astro';
import data from '../data/portfolio.json';
import { withBase } from '../lib/url';

const destaques = data.acervo.filter((item) => item.destaque);
const heroUrl = (w: number) =>
  `${data.hero.src}?auto=format&fit=crop&q=80&w=${w}`;
---

<Layout title="Aragão · Fotografia de carros antigos">
  <!-- HERO: revelação de câmara escura. A Pagode verde emerge do fundo
       verde-preto; o título sobe linha a linha. -->
  <section class="hero">
    <div class="hero-img">
      <img
        src={heroUrl(1400)}
        srcset={`${heroUrl(900)} 900w, ${heroUrl(1400)} 1400w, ${heroUrl(2000)} 2000w`}
        sizes="(max-width: 900px) 100vw, 60vw"
        alt={data.hero.alt}
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="container hero-texto">
      <p class="plate hero-plate">Aragão · Fotografia de clássicos</p>
      <h1>
        <span class="linha"><span class="sobe">O tempo estaciona.</span></span>
        <span class="linha"><span class="sobe"><em>A luz</em> continua.</span></span>
      </h1>
      <p class="lede">
        Ensaios autorais de carros antigos, da garagem do colecionador aos
        grandes encontros de clássicos. Cada carro entra no acervo com ficha
        própria: modelo, ano e a história de quem o manteve vivo.
      </p>
      <a class="cta" href={withBase('/portfolio')}>Ver o acervo <span aria-hidden="true">→</span></a>
    </div>
    <p class="plate hero-ficha" aria-hidden="true">
      {data.hero.modelo} · {data.hero.ano} · {data.hero.nota}
    </p>
  </section>

  <!-- Esteira lenta com os modelos do acervo -->
  <section class="marquee" aria-hidden="true">
    <div class="trilho">
      {[0, 1].map(() => (
        <span class="fila">
          {data.marquee.map((m) => (
            <span class="modelo">{m}<span class="rebite"></span></span>
          ))}
        </span>
      ))}
    </div>
  </section>

  <!-- Destaques do acervo -->
  <section class="container secao">
    <div class="secao-head reveal">
      <p class="plate">Acervo · seleção</p>
      <a class="link-acervo" href={withBase('/portfolio')}>Catálogo completo →</a>
    </div>
    <Gallery images={destaques} />
  </section>

  <!-- Manifesto -->
  <section class="manifesto">
    <div class="container reveal">
      <p class="plate">Manifesto</p>
      <blockquote>
        Não fotografo carros. Fotografo <em>o cuidado</em> de quem os manteve
        vivos: o cromo polido de domingo, a pátina que ninguém teve coragem
        de apagar.
      </blockquote>
    </div>
  </section>

  <!-- Ensaios -->
  <section class="container secao">
    <div class="secao-head reveal">
      <p class="plate">Ensaios</p>
      <a class="link-acervo" href={withBase('/servicos')}>Como funciona →</a>
    </div>
    <div class="ensaios">
      {
        data.ensaios.map((e, i) => (
          <a href={withBase('/servicos')} class="ensaio reveal" style={`--delay: ${i * 120}ms`}>
            <h3>{e.titulo}</h3>
            <p>{e.descricao}</p>
            <span class="saiba">Saber mais →</span>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  /* ---------- HERO ---------- */
  .hero {
    position: relative;
    min-height: calc(100svh - 76px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-img {
    position: absolute;
    inset: 0 0 0 auto;
    width: 62%;
    animation: revelar 2.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  /* Vinheta que funde a foto (fundo preto) com o verniz verde do site */
  .hero-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, var(--verniz) 0%, rgba(17, 24, 18, 0) 35%),
      linear-gradient(0deg, var(--verniz) 0%, rgba(17, 24, 18, 0) 30%),
      linear-gradient(180deg, rgba(17, 24, 18, 0.5) 0%, rgba(17, 24, 18, 0) 25%);
  }

  @keyframes revelar {
    from {
      opacity: 0;
      transform: scale(1.05);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .hero-texto {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 96px;
    padding-bottom: 112px;
  }

  .hero-plate {
    animation: surgir 0.9s ease 1.5s both;
  }

  h1 {
    font-size: clamp(2.9rem, 7.5vw, 5.8rem);
    margin: 30px 0 28px;
    max-width: 12ch;
  }

  .linha {
    display: block;
    overflow: hidden;
  }

  .sobe {
    display: block;
    animation: subir 1.1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .linha:nth-child(1) .sobe {
    animation-delay: 0.5s;
  }

  .linha:nth-child(2) .sobe {
    animation-delay: 0.72s;
  }

  @keyframes subir {
    from {
      transform: translateY(110%);
    }
    to {
      transform: none;
    }
  }

  @keyframes surgir {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .lede {
    color: var(--cromo);
    font-size: 1.02rem;
    max-width: 46ch;
    margin: 0 0 40px;
    animation: surgir 0.9s ease 1.2s both;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--marfim);
    border: 1px solid var(--latao);
    padding: 14px 26px;
    transition:
      background 0.3s ease,
      color 0.3s ease;
    animation: surgir 0.9s ease 1.4s both;
  }

  .cta:hover {
    background: var(--rubi);
    border-color: var(--rubi);
  }

  .hero-ficha {
    position: absolute;
    right: 32px;
    bottom: 32px;
    z-index: 2;
    animation: surgir 0.9s ease 1.8s both;
  }

  /* ---------- MARQUEE ---------- */
  .marquee {
    border-top: 1px solid var(--linha);
    border-bottom: 1px solid var(--linha);
    overflow: hidden;
    padding: 18px 0;
    background: var(--fosso);
  }

  .trilho {
    display: flex;
    width: max-content;
    animation: correr 48s linear infinite;
  }

  .fila {
    display: flex;
    flex: none;
  }

  .modelo {
    display: inline-flex;
    align-items: center;
    gap: 28px;
    padding-right: 28px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cromo);
    white-space: nowrap;
  }

  .rebite {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--latao);
  }

  @keyframes correr {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .trilho {
      animation: none;
    }
  }

  /* ---------- SEÇÕES ---------- */
  .secao {
    padding-top: 110px;
  }

  .secao-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 56px;
  }

  .link-acervo {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cromo);
    border-bottom: 1px solid transparent;
    padding-bottom: 3px;
    transition:
      color 0.25s ease,
      border-color 0.25s ease;
  }

  .link-acervo:hover {
    color: var(--marfim);
    border-color: var(--latao);
  }

  /* ---------- MANIFESTO ---------- */
  .manifesto {
    margin-top: 120px;
    border-top: 1px solid var(--linha);
    border-bottom: 1px solid var(--linha);
    background: var(--fosso);
    padding: 110px 0;
  }

  blockquote {
    font-family: var(--font-display);
    font-weight: 340;
    font-variation-settings: 'opsz' 144;
    font-size: clamp(1.7rem, 4vw, 3rem);
    line-height: 1.25;
    max-width: 26ch;
    margin: 30px 0 0;
  }

  blockquote em {
    font-style: italic;
    color: var(--rubi);
  }

  /* ---------- ENSAIOS ---------- */
  .ensaios {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .ensaio {
    border: 1px solid var(--linha);
    padding: 36px 30px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition:
      border-color 0.3s ease,
      background 0.3s ease;
  }

  .ensaio:hover {
    border-color: var(--latao);
    background: var(--fosso);
  }

  .ensaio h3 {
    font-size: 1.5rem;
  }

  .ensaio p {
    color: var(--cromo);
    font-size: 0.92rem;
    margin: 0;
    flex: 1;
  }

  .saiba {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--latao);
  }

  /* ---------- RESPONSIVO ---------- */
  @media (max-width: 900px) {
    /* No mobile a foto e o texto empilham de verdade: imagem em bloco no
       topo, texto embaixo em fundo solido — sem sobreposicao ilegivel. */
    .hero {
      display: block;
      min-height: 0;
      overflow: visible;
    }

    .hero-img {
      position: relative;
      inset: auto;
      width: 100%;
      /* Recorte mais fechado no carro para cortar o excesso de fundo
         escuro acima e abaixo dele na foto original. */
      aspect-ratio: 1 / 1;
    }

    .hero-img img {
      object-position: center 52%;
    }

    .hero-img::after {
      background: linear-gradient(
        180deg,
        rgba(17, 24, 18, 0) 65%,
        var(--verniz) 100%
      );
    }

    .hero-texto {
      padding-top: 40px;
      padding-bottom: 72px;
    }

    h1 {
      margin-top: 22px;
    }

    .hero-ficha {
      display: none;
    }

    .ensaios {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-img,
    .hero-plate,
    .sobe,
    .lede,
    .cta,
    .hero-ficha {
      animation: none;
    }
  }
</style>
