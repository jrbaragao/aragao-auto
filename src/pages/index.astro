---
import Layout from '../layouts/Layout.astro';
import Gallery from '../components/Gallery.astro';
import data from '../data/portfolio.json';
---

<Layout title="Fotografia Automotiva Profissional | LENTE&CHASSI">
  <section class="hero container">
    <p class="eyebrow">Fotografia automotiva profissional</p>
    <h1>
      Imagens que vendem<br />
      o carro antes da primeira volta.
    </h1>
    <p class="lede">
      Producao para concessionarias, colecionadores e marcas do setor
      automotivo. Estudio, externa e cobertura de eventos.
    </p>
    <a class="cta" href="/portfolio">Ver portfolio completo &rarr;</a>
  </section>

  <section class="container section">
    <div class="section-head">
      <h2>Destaques</h2>
      <a href="/portfolio">Portfolio completo</a>
    </div>
    <Gallery images={data.destaques} />
  </section>

  <section class="container section services">
    <h2>Servicos</h2>
    <div class="service-grid">
      {
        data.servicos.map((s) => (
          <div class="service-card">
            <h3>{s.titulo}</h3>
            <p>{s.descricao}</p>
          </div>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 96px 24px 64px;
    max-width: 900px;
  }

  h1 {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.1;
    margin: 16px 0 24px;
  }

  .lede {
    color: var(--fg-muted);
    font-size: 1.05rem;
    max-width: 52ch;
    margin-bottom: 32px;
  }

  .cta {
    display: inline-block;
    border-bottom: 1px solid var(--accent);
    color: var(--accent);
    padding-bottom: 4px;
    font-size: 0.95rem;
  }

  .section {
    padding: 48px 24px;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 24px;
  }

  .section-head a {
    font-size: 0.85rem;
    color: var(--fg-muted);
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 24px;
  }

  .service-card {
    border: 1px solid var(--border);
    padding: 28px;
  }

  .service-card h3 {
    font-size: 1.15rem;
    margin-bottom: 12px;
  }

  .service-card p {
    color: var(--fg-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 800px) {
    .service-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
