---
// Em producao, `images` vem do CMS headless (Payload/Sanity) via query
// feita em build-time (getStaticProps equivalente do Astro).
// As urls ja chegam otimizadas pelo CDN de imagem (Cloudinary/imgix):
// resize, formato (AVIF/WebP) e qualidade definidos por parametro na URL.
interface GalleryImage {
  src: string;
  alt: string;
  tag?: string;
}

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
---

<div class="gallery">
  {
    images.map((img, i) => (
      <figure class={i === 0 ? 'featured' : ''}>
        <img
          src={img.src}
          alt={img.alt}
          loading={i < 2 ? 'eager' : 'lazy'}
          decoding="async"
          width="1200"
          height="800"
        />
        {img.tag && <figcaption>{img.tag}</figcaption>}
      </figure>
    ))
  }
</div>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
  }

  figure {
    position: relative;
    margin: 0;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--bg-elevated);
  }

  figure.featured {
    grid-column: span 2;
    grid-row: span 2;
    aspect-ratio: 4 / 3;
  }

  figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  figure:hover img {
    transform: scale(1.04);
  }

  figcaption {
    position: absolute;
    left: 12px;
    bottom: 12px;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(0, 0, 0, 0.55);
    padding: 4px 10px;
  }

  @media (max-width: 900px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
    }
    figure.featured {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
</style>
