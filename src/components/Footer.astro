---
const year = new Date().getFullYear();
---

<footer class="site-footer" id="contato">
  <div class="container grid">
    <div>
      <h3>Vamos fotografar seu carro.</h3>
      <p class="muted">
        Atendimento para concessionarias, colecionadores e marcas.
      </p>
    </div>
    <div class="contact">
      <a href="mailto:contato@seudominio.com.br">contato@seudominio.com.br</a>
      <a href="https://wa.me/5500000000000">WhatsApp</a>
      <a href="https://instagram.com/seuinstagram">Instagram</a>
    </div>
  </div>
  <div class="container">
    <p class="legal">&copy; {year} - Todos os direitos reservados.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 64px 0 24px;
    margin-top: 96px;
  }

  .grid {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 32px;
    padding-bottom: 32px;
  }

  .muted {
    color: var(--fg-muted);
    max-width: 32ch;
  }

  .contact {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-end;
    font-size: 0.9rem;
  }

  .contact a:hover {
    color: var(--accent);
  }

  .legal {
    color: var(--fg-muted);
    font-size: 0.75rem;
    border-top: 1px solid var(--border);
    padding-top: 24px;
  }

  @media (max-width: 640px) {
    .contact {
      align-items: flex-start;
    }
  }
</style>
